@app.route("/attendance")
def attendance():
    if not os.path.exists(MODEL_FILE):
        return jsonify({"message": "Please train AI model first", "unknown_detected": False})
    
    df_students = pd.read_excel(DATA_FILE)
    df_att = pd.read_excel(ATT_FILE)
    
    # Ensure Status column exists
    if "Status" not in df_att.columns:
        df_att["Status"] = "Present"
    
    recognizer.read(MODEL_FILE)
    
    cam = cv2.VideoCapture(0)
    unknown_count = 0
    last_unknown_time = None
    
    attendance_marked = False
    result_message = "No face detected"
    
    # Add parent phone column if not exists
    if "ParentPhone" not in df_students.columns:
        df_students["ParentPhone"] = ""
    
    while True:
        ret, img = cam.read()
        if not ret:
            continue
            
        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        faces = face_detector.detectMultiScale(gray, 1.3, 5)
        
        for (x, y, w, h) in faces:
            face = gray[y:y+h, x:x+w]
            face = cv2.resize(face, (200, 200))
            
            sid, conf = recognizer.predict(face)
            
            # Confidence threshold - lower is better for LBPH
            if conf < 80:
                student = df_students[df_students["ID"] == sid]
                
                if not student.empty:
                    name = student.iloc[0]["Name"]
                    parent_phone = student.iloc[0].get("ParentPhone", "")
                    
                    now = datetime.datetime.now()
                    today = now.date()
                    
                    # Check if already marked today
                    already_marked = ((df_att["ID"] == sid) & (df_att["Date"] == today)).any()
                    
                    if not already_marked:
                        # Mark attendance
                        new_record = pd.DataFrame([{
                            "ID": sid,
                            "Name": name,
                            "Date": today,
                            "Time": now.time(),
                            "Status": "Present"
                        }])
                        df_att = pd.concat([df_att, new_record], ignore_index=True)
                        df_att.to_excel(ATT_FILE, index=False)
                        
                        # Get attendance percentage
                        percentage = get_student_attendance_percentage(sid)
                        
                        # Send SMS to parent
                        sms_sent = send_parent_sms(sid, name, parent_phone, "Present")
                        
                        # Voice announcement with attendance info
                        if percentage < 50:
                            speak(f"Hello {name}, your attendance is marked. Warning: Your attendance is {percentage:.0f} percent. Please improve.")
                        else:
                            speak(f"Hello {name}, your attendance has been recorded. Your attendance is {percentage:.0f} percent.")
                        
                        # Check for low attendance alert
                        if percentage < 50:
                            result_message = f"⚠️ LOW ATTENTION ALERT: {name} marked present but has {percentage:.1f}% attendance!"
                        else:
                            result_message = f"✅ Attendance marked for {name}. SMS sent to parent."
                        
                        attendance_marked = True
                        
                        # Draw success rectangle
                        cv2.rectangle(img, (x, y), (x+w, y+h), (0, 255, 0), 3)
                        cv2.putText(img, f"{name} - Present", (x, y-10), 
                                   cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0, 255, 0), 2)
                        
                        cv2.imshow("Attendance System", img)
                        cv2.waitKey(2000)  # Show for 2 seconds
                        
                    else:
                        result_message = f"{name} already marked present today"
                        speak(f"{name}, you are already marked present today")
                        attendance_marked = True
                    
                    cam.release()
                    cv2.destroyAllWindows()
                    return jsonify({"message": result_message, "unknown_detected": False})
                
            else:
                # Unknown face detected
                unknown_count += 1
                cv2.rectangle(img, (x, y), (x+w, y+h), (0, 0, 255), 3)
                cv2.putText(img, "Unknown", (x, y-10), 
                           cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0, 0, 255), 2)
                
                # Alert after 5 consecutive unknown detections
                if unknown_count >= 5:
                    speak("Warning! Unknown person detected!")
                    cam.release()
                    cv2.destroyAllWindows()
                    return jsonify({
                        "message": "🚨 SECURITY ALERT: Unknown person detected! Access denied.",
                        "unknown_detected": True
                    })
        
        cv2.imshow("Attendance System - Press ESC to exit", img)
        
        if cv2.waitKey(1) == 27:
            break
    
    cam.release()
    cv2.destroyAllWindows()
    
    return jsonify({"message": result_message, "unknown_detected": False})

@app.route("/stop_camera")
def stop_camera():
    cv2.destroyAllWindows()
    return jsonify({"message": "Camera stopped"})

