def train_model():
    faces = []
    ids = []

    for file in os.listdir("faces"):
        path = os.path.join("faces", file)
        img = cv2.imread(path, 0)
        if img is None:
            continue
        img = cv2.resize(img, (200, 200))
        
        try:
            sid = int(file.split("_")[0])
            faces.append(img)
            ids.append(sid)
        except:
            continue

    if len(faces) > 0:
        recognizer.train(faces, np.array(ids))
        recognizer.save(MODEL_FILE)
        return True
    return False

