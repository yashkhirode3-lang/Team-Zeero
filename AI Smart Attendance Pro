@app.route("/register", methods=["POST"])
def register():
    data = request.json
    
    name = data["name"]
    sid = int(data["id"])
    email = data["email"]
    parent_phone = data.get("parent_phone", "")
    
    df = pd.read_excel(DATA_FILE)
    
    if sid in df["ID"].values:
        return jsonify({"message": "Student already registered", "success": False})
    
    # Add parent phone column if not exists
    if "ParentPhone" not in df.columns:
        df["ParentPhone"] = ""
    
    new_row = pd.DataFrame([{"ID": sid, "Name": name, "Email": email, "ParentPhone": parent_phone}])
    df = pd.concat([df, new_row], ignore_index=True)
    df.to_excel(DATA_FILE, index=False)
    
    cam = cv2.VideoCapture(0)
    count = 0
    
    speak(f"Starting registration for {name}. Please look at the camera.")
    
    while True:
        ret, img = cam.read()
        if not ret:
            continue
            
        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        faces = face_detector.detectMultiScale(gray, 1.3, 5)
        
        for (x, y, w, h) in faces:
            face = gray[y:y+h, x:x+w]
            face = cv2.resize(face, (200, 200))
            
            count += 1
            cv2.imwrite(f"faces/{sid}_{count}.jpg", face)
            cv2.rectangle(img, (x, y), (x+w, y+h), (255, 0, 0), 2)
            
            # Voice feedback every 5 samples
            if count % 5 == 0:
                speak(f"{count} samples collected")
        
        cv2.imshow("Register Face - Press ESC to cancel", img)
        
        if count >= 20:
            speak(f"Registration complete for {name}")
            break
            
        if cv2.waitKey(1) == 27:
            break
    
    cam.release()
    cv2.destroyAllWindows()
    
    return jsonify({"message": f"Student {name} registered with 20 face samples", "success": True})

