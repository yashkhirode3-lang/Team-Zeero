def analyze_attendance():
    """AI-powered attendance analysis"""
    try:
        df_att = pd.read_excel(ATT_FILE)
        df_students = pd.read_excel(DATA_FILE)
        
        if df_att.empty or df_students.empty:
            return {}
        
        analysis = {
            "last_updated": datetime.datetime.now().isoformat(),
            "summary": {},
            "low_attendance_alerts": [],
            "daily_stats": {},
            "monthly_report": {}
        }
        
        # Calculate working days (last 30 days)
        today = datetime.date.today()
        working_days = set()
        for i in range(30):
            d = today - datetime.timedelta(days=i)
            if d.weekday() < 5:  # Monday = 0, Friday = 4
                working_days.add(d)
        
        total_working_days = len(working_days)
        
        # Analyze each student
        for _, student in df_students.iterrows():
            sid = student["ID"]
            name = student["Name"]
            
            # Get attendance records for this student
            student_records = df_att[df_att["ID"] == sid]
            present_days = len(student_records[student_records["Status"] == "Present"])
            absent_days = len(student_records[student_records["Status"] == "Absent"])
            
            # Calculate percentage
            if total_working_days > 0:
                percentage = (present_days / total_working_days) * 100
            else:
                percentage = 0
            
            analysis["summary"][str(sid)] = {
                "name": name,
                "present_days": present_days,
                "absent_days": absent_days,
                "total_working_days": total_working_days,
                "percentage": round(percentage, 2),
                "status": "Good" if percentage >= 75 else "Average" if percentage >= 50 else "Poor"
            }
            
            # Low attendance alert
            if percentage < 50:
                analysis["low_attendance_alerts"].append({
                    "id": sid,
                    "name": name,
                    "percentage": round(percentage, 2),
                    "message": f"⚠️ ALERT: {name} has low attendance ({percentage:.1f}%). Immediate action required!"
                })
        
        # Daily statistics
        last_7_days = [(today - datetime.timedelta(days=i)).isoformat() for i in range(7)]
        for date_str in last_7_days:
            date_obj = datetime.date.fromisoformat(date_str)
            day_records = df_att[df_att["Date"] == date_obj]
            analysis["daily_stats"][date_str] = {
                "present": len(day_records[day_records["Status"] == "Present"]),
                "absent": len(day_records[day_records["Status"] == "Absent"]),
                "total_students": len(df_students)
            }
        
        # Save analysis
        with open(ANALYSIS_FILE, 'w') as f:
            json.dump(analysis, f, indent=2, default=str)
        
        return analysis
        
    except Exception as e:
        print(f"Analysis Error: {e}")
        return {}

def get_student_attendance_percentage(student_id):
    """Get real-time attendance percentage for a student"""
    try:
        with open(ANALYSIS_FILE, 'r') as f:
            analysis = json.load(f)
        
        student_data = analysis.get("summary", {}).get(str(student_id), {})
        return student_data.get("percentage", 0)
    except:
        return 0

